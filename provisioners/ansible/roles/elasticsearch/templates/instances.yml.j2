# Generated by Ansible - used as input to `elasticsearch-certutil http --in`
# This replaces the interactive "Hostnames:" prompt in the manual wizard.
instances:
{% for host in es_group_node %}
{% set hv = hostvars[host] %}
{% set node_label = hv.tags.Name | default(host) %}
  - name: "{{ node_label }}"
    ip:
      - "{{ hv.private_ip_address }}"
      - "{{ hv.public_ip_address }}"
      - "127.0.0.1"
    dns:
      - "{{ node_label }}"
      - "localhost"
{% if hv.private_dns_name is defined %}
      - "{{ hv.private_dns_name }}"
{% endif %}
{% endfor %}